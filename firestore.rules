rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isValidChatRecord(data) {
      return data.keys().hasAll(['query', 'messages', 'timestamp'])
        && data.query is string
        && data.messages is list
        && data.timestamp is number;
    }
    
    function isValidChatUpdate(data) {
      return data.keys().hasAll(['messages', 'timestamp'])
        && data.messages is list
        && data.timestamp is number;
    }
    
    match /users/{userId}/chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isValidId(chatId)
        && isValidChatRecord(incoming());
      allow update: if isSignedIn()
         && request.auth.uid == userId
         && isValidChatUpdate(incoming());
    }
  }
}
